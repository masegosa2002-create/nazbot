---
import "@fontsource-variable/inter";
import Header from "~/components/header.astro";
import Footer from "~/components/footer.astro";
import "~/styles/index.css";

interface Props {
  title: string;
  description?: string;
  lastUpdated?: string;
}

const { title, description = "", lastUpdated } = Astro.props;
---

<!doctype html>
<html lang="es" class="h-full motion-safe:scroll-smooth" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | AgenteGestión</title>
    {description && <meta name="description" content={description} />}
    <meta name="robots" content="noindex, follow" />
  </head>

  <body class="h-full overflow-x-hidden bg-default text-default">
    <Header />

    <main class="mx-auto max-w-3xl px-6 pb-24 pt-32 lg:px-8">
      <!-- Back link -->
      <a
        href="/"
        class="mb-10 inline-flex items-center gap-2 text-xs text-offset transition-colors hover:text-white"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M19 12H5M12 5l-7 7 7 7" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        Volver al inicio
      </a>

      <!-- Header -->
      <div class="mb-12 border-b border-white/[0.07] pb-8">
        <h1 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl">{title}</h1>
        {lastUpdated && (
          <p class="mt-3 text-sm text-offset">Última actualización: {lastUpdated}</p>
        )}
      </div>

      <!-- Content -->
      <div class="legal-content">
        <slot />
      </div>
    </main>

    <Footer />
  </body>
</html>

<style is:global>
  .legal-content h2 {
    font-size: 1.125rem;
    font-weight: 700;
    color: #f0f0f0;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .legal-content h3 {
    font-size: 0.95rem;
    font-weight: 600;
    color: rgba(240, 240, 240, 0.85);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .legal-content p {
    font-size: 0.875rem;
    line-height: 1.75;
    color: #8f8f8f;
    margin-bottom: 1rem;
  }

  .legal-content ul {
    list-style: disc;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .legal-content ul li {
    font-size: 0.875rem;
    line-height: 1.75;
    color: #8f8f8f;
    margin-bottom: 0.25rem;
  }

  .legal-content a {
    color: rgba(255, 255, 255, 0.75);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .legal-content a:hover {
    color: #f0f0f0;
  }

  .legal-content strong {
    color: rgba(240, 240, 240, 0.9);
    font-weight: 600;
  }

  .legal-info-box {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1.5rem;
  }

  .legal-info-box p {
    margin-bottom: 0.25rem;
  }

  .legal-info-box p:last-child {
    margin-bottom: 0;
  }
</style>
