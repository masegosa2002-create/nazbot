---
const pasos = [
  { num: "01", label: "Captación", desc: "Web, WhatsApp, formularios. Todos los canales conectados." },
  { num: "02", label: "Respuesta automática", desc: "Primera respuesta rápida antes de que el lead enfríe." },
  { num: "03", label: "Cualificación", desc: "Preguntas clave para saber si es un lead real y qué quiere." },
  { num: "04", label: "Agenda", desc: "Cita o llamada reservada directamente desde el chat." },
  { num: "05", label: "Seguimiento", desc: "Recordatorios y recontacto automático hasta cerrar o descartar." },
  { num: "06", label: "Cierre y control", desc: "Todo registrado y visible. Sabes en qué punto está cada oportunidad." },
];
const canales = [
  {
    label: "WhatsApp + Webchat",
    sub: "Respuesta en segundos",
    svg: `<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>`,
  },
  {
    label: "Agenda conectada",
    sub: "Citas sin intervención",
    svg: `<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>`,
  },
  {
    label: "Panel centralizado",
    sub: "Todos los leads visibles",
    svg: `<rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>`,
  },
  {
    label: "Seguimiento automático",
    sub: "Hasta cerrar o descartar",
    svg: `<polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>`,
  },
];
---

<section id="como-funciona" class="section-py relative bg-[#0b0b0b]">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/8 to-transparent"></div>

  <div class="mx-auto max-w-6xl px-6 lg:px-12">
    <div class="mb-16 text-center reveal">
      <span class="section-tag">Cómo funciona</span>
      <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-white sm:text-4xl lg:text-5xl">
        Así funciona
        <span class="gradient-text"> el sistema que instalamos</span>
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-white/50">
        No vendemos un chatbot suelto. Vendemos un sistema comercial automatizado para que el lead
        entre, reciba respuesta, avance y no se pierda.
      </p>
    </div>

    <!-- Flujo 6 pasos -->
    <div class="flujo-grid reveal mb-14">
      {pasos.map((p, i) => (
        <div class={`flujo-paso reveal delay-${(i + 1) * 100}`}>
          <div class="flujo-num">{p.num}</div>
          <div class="flujo-label">{p.label}</div>
          <div class="flujo-desc">{p.desc}</div>
          {i < pasos.length - 1 && (
            <div class="flujo-arrow">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- Canales -->
    <div class="canales-row reveal">
      {canales.map((c) => (
        <div class="canal-card">
          <div class="canal-ico">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={c.svg}></svg>
          </div>
          <div>
            <p class="canal-label">{c.label}</p>
            <p class="canal-sub">{c.sub}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .flujo-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 480px) {
    .flujo-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 768px) {
    .flujo-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (min-width: 1024px) {
    .flujo-grid { grid-template-columns: repeat(6, 1fr); }
  }
  .flujo-paso {
    position: relative;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 12px;
    padding: 1.25rem 1rem;
    transition: border-color 0.2s ease;
  }
  .flujo-paso:hover { border-color: rgba(79,158,255,0.2); }
  .flujo-num { font-size: 0.65rem; font-weight: 700; letter-spacing: 0.08em; color: rgba(79,158,255,0.5); margin-bottom: 0.5rem; }
  .flujo-label { font-size: 0.85rem; font-weight: 700; color: rgba(255,255,255,0.85); margin-bottom: 0.375rem; }
  .flujo-desc { font-size: 0.72rem; line-height: 1.4; color: rgba(255,255,255,0.38); }
  .flujo-arrow {
    display: none;
  }
  @media (min-width: 1024px) {
    .flujo-arrow {
      display: block;
      position: absolute; right: -0.9rem; top: 50%;
      transform: translateY(-50%);
      color: rgba(79,158,255,0.2); z-index: 1;
    }
  }
  .canales-row {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem;
  }
  @media (min-width: 640px) { .canales-row { grid-template-columns: repeat(4, 1fr); } }
  .canal-card {
    display: flex; align-items: center; gap: 0.875rem;
    padding: 1rem 1.25rem;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 12px;
    transition: border-color 0.2s ease;
  }
  .canal-card:hover { border-color: rgba(79,158,255,0.18); }
  .canal-ico {
    display: flex; align-items: center; justify-content: center;
    width: 34px; height: 34px; flex-shrink: 0;
    background: rgba(79,158,255,0.06);
    border: 1px solid rgba(79,158,255,0.15);
    border-radius: 9px; color: rgba(79,158,255,0.7);
  }
  .canal-label { font-size: 0.8rem; font-weight: 600; color: rgba(255,255,255,0.8); }
  .canal-sub { font-size: 0.68rem; color: rgba(255,255,255,0.3); margin-top: 0.1rem; }
</style>
