---
const flujo = [
  { label: "Captación", desc: "Lead entra por WhatsApp, web o anuncio" },
  { label: "Respuesta", desc: "El sistema responde en segundos" },
  { label: "Cualificación", desc: "Preguntas automáticas para filtrar intención" },
  { label: "Cita", desc: "Agenda directamente en tu calendario" },
  { label: "Seguimiento", desc: "Hasta 4 intentos si no responde" },
  { label: "Cierre", desc: "Tú entras con el lead ya preparado" },
];

const canales = [
  {
    icon: "💬",
    nombre: "WhatsApp Business",
    desc: "El canal donde ya están tus clientes. Respuesta y seguimiento automático.",
  },
  {
    icon: "🌐",
    nombre: "Webchat",
    desc: "El chat de tu web convierte visitas en conversaciones cualificadas.",
  },
  {
    icon: "📅",
    nombre: "Agenda",
    desc: "Integración con tu calendario. Las citas se bloquean solas.",
  },
  {
    icon: "📊",
    nombre: "Panel de control",
    desc: "Todos los leads, estados y conversaciones en un sitio. Sin Excel.",
  },
];
---

<section id="solucion" class="section-py relative bg-[#0d0d0d]">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>

  <div class="mx-auto max-w-6xl px-6 lg:px-12">

    <!-- Header -->
    <div class="mb-16 text-center reveal">
      <span class="section-tag">La solución</span>
      <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-white sm:text-4xl lg:text-5xl">
        Un sistema que trabaja
        <span class="gradient-text"> desde el primer contacto hasta la cita.</span>
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-offset">
        Lo instalamos en 10–14 días. A partir de ahí, funciona solo.
        Tú ves los resultados en el panel.
      </p>
    </div>

    <!-- Flujo visual -->
    <div class="flujo-container mb-20 reveal">
      <div class="flujo-title">El recorrido de cada lead</div>
      <div class="flujo-pasos">
        {flujo.map((paso, i) => (
          <div class="flujo-paso">
            <div class="flujo-num">{String(i + 1).padStart(2, "0")}</div>
            <div class="flujo-label">{paso.label}</div>
            <div class="flujo-desc">{paso.desc}</div>
            {i < flujo.length - 1 && (
              <div class="flujo-arrow">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>

    <!-- Canales -->
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4 reveal">
      {canales.map((c, i) => (
        <div class={`canal-card reveal delay-${(i + 1) * 100}`}>
          <div class="canal-icon">{c.icon}</div>
          <h3 class="mt-3 text-sm font-semibold text-white">{c.nombre}</h3>
          <p class="mt-2 text-xs leading-relaxed text-offset">{c.desc}</p>
        </div>
      ))}
    </div>

    <!-- Nota -->
    <div class="mt-10 text-center reveal">
      <p class="text-sm text-offset/50">
        El sistema no impone herramientas. Se adapta a tu agenda actual y lo integramos todo.
      </p>
    </div>

  </div>
</section>

<style>
  .section-py {
    padding-top: 7rem;
    padding-bottom: 7rem;
  }

  .flujo-container {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 14px;
    padding: 2rem;
    overflow-x: auto;
  }

  .flujo-title {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.25);
    margin-bottom: 1.5rem;
  }

  .flujo-pasos {
    display: flex;
    align-items: flex-start;
    gap: 0;
    min-width: 640px;
  }

  .flujo-paso {
    position: relative;
    flex: 1;
    padding-right: 1.5rem;
  }

  .flujo-num {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.2);
    margin-bottom: 0.5rem;
  }

  .flujo-label {
    font-size: 0.875rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 0.375rem;
  }

  .flujo-desc {
    font-size: 0.72rem;
    line-height: 1.4;
    color: rgba(255, 255, 255, 0.4);
  }

  .flujo-arrow {
    position: absolute;
    right: -0.25rem;
    top: 1.4rem;
    color: rgba(255, 255, 255, 0.15);
  }

  .canal-card {
    background: rgba(255, 255, 255, 0.025);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 12px;
    padding: 1.5rem;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .canal-card:hover {
    border-color: rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.04);
  }

  .canal-icon {
    font-size: 1.5rem;
    line-height: 1;
  }
</style>
