---
const pasos = [
  { num: "01", label: "Captación", desc: "Web, WhatsApp, formularios. Todos los canales conectados." },
  { num: "02", label: "Respuesta automática", desc: "Primera respuesta rápida antes de que el lead enfríe." },
  { num: "03", label: "Cualificación", desc: "Preguntas clave para saber si es un lead real y qué quiere." },
  { num: "04", label: "Agenda", desc: "Cita o llamada reservada directamente desde el chat." },
  { num: "05", label: "Seguimiento", desc: "Recordatorios y recontacto automático hasta cerrar o descartar." },
  { num: "06", label: "Cierre y control", desc: "Todo registrado y visible. Sabes en qué punto está cada oportunidad." },
];
const canales = [
  { ico: "💬", label: "WhatsApp + webchat" },
  { ico: "📅", label: "Agenda conectada" },
  { ico: "📊", label: "Panel tipo CRM" },
  { ico: "🔁", label: "Seguimiento automático" },
];
---

<section id="como-funciona" class="section-py relative bg-[#0b0b0b]">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/8 to-transparent"></div>

  <div class="mx-auto max-w-6xl px-6 lg:px-12">
    <div class="mb-16 text-center reveal">
      <span class="section-tag">Cómo funciona</span>
      <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-white sm:text-4xl lg:text-5xl">
        Así funciona
        <span class="gradient-text"> el sistema que instalamos</span>
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-white/50">
        No vendemos un chatbot suelto. Vendemos un sistema comercial automatizado para que el lead
        entre, reciba respuesta, avance y no se pierda.
      </p>
    </div>

    <!-- Flujo 6 pasos -->
    <div class="flujo-grid reveal mb-14">
      {pasos.map((p, i) => (
        <div class={`flujo-paso reveal delay-${(i + 1) * 100}`}>
          <div class="flujo-num">{p.num}</div>
          <div class="flujo-label">{p.label}</div>
          <div class="flujo-desc">{p.desc}</div>
          {i < pasos.length - 1 && (
            <div class="flujo-arrow">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- Canales micro -->
    <div class="canales-row reveal">
      {canales.map((c) => (
        <div class="canal-pill">
          <span>{c.ico}</span>
          <span class="text-sm text-white/60 font-medium">{c.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section-py { padding-top: 7rem; padding-bottom: 7rem; }
  .flujo-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  @media (min-width: 768px) {
    .flujo-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (min-width: 1024px) {
    .flujo-grid { grid-template-columns: repeat(6, 1fr); }
  }
  .flujo-paso {
    position: relative;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 12px;
    padding: 1.25rem 1rem;
    transition: border-color 0.2s ease;
  }
  .flujo-paso:hover { border-color: rgba(79,158,255,0.2); }
  .flujo-num { font-size: 0.65rem; font-weight: 700; letter-spacing: 0.08em; color: rgba(79,158,255,0.5); margin-bottom: 0.5rem; }
  .flujo-label { font-size: 0.85rem; font-weight: 700; color: rgba(255,255,255,0.85); margin-bottom: 0.375rem; }
  .flujo-desc { font-size: 0.72rem; line-height: 1.4; color: rgba(255,255,255,0.38); }
  .flujo-arrow {
    display: none;
  }
  @media (min-width: 1024px) {
    .flujo-arrow {
      display: block;
      position: absolute; right: -0.9rem; top: 50%;
      transform: translateY(-50%);
      color: rgba(79,158,255,0.2); z-index: 1;
    }
  }
  .canales-row {
    display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: center;
  }
  .canal-pill {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: rgba(79,158,255,0.04);
    border: 1px solid rgba(79,158,255,0.12);
    border-radius: 100px;
  }
</style>
