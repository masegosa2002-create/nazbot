---
const WA_URL = "https://wa.me/34659426999?text=SISTEMA";

const faqs = [
  {
    q: "¿Esto reemplaza a mi equipo?",
    a: "No. Libera a tu equipo de tareas repetitivas (responder lo mismo, hacer seguimientos manuales, actualizar listas) y les deja tiempo para lo que importa: cerrar.",
  },
  {
    q: "¿Y si ya contestamos nosotros?",
    a: "El sistema ayuda a responder antes, más rápido y de forma más ordenada. También hace el seguimiento que vuestro equipo no hace porque tiene otras prioridades.",
  },
  {
    q: "¿Esto sirve para cualquier negocio?",
    a: "No para todos. Funciona mejor donde hay leads, conversaciones y seguimiento: servicios, clínicas, agencias, B2B. Si no sabes si es para ti, cuéntame tu caso.",
  },
  {
    q: "¿Cuánto tarda?",
    a: "10–14 días desde que recibo los accesos. Después, 1 semana de estabilización. Total: entre 3 y 4 semanas hasta que el sistema va solo.",
  },
  {
    q: "¿Y si mi caso es más complejo?",
    a: "Cuéntamelo por WhatsApp y lo miramos juntos. Sin compromiso.",
  },
  {
    q: "¿Incluye mantenimiento?",
    a: "El sprint incluye garantía de 15 días. Para soporte continuado, hay planes de mantenimiento opcionales que puedes añadir después según lo que necesites.",
  },
];
---

<section id="faq" class="section-py relative bg-[#0b0b0b]">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/8 to-transparent"></div>

  <div class="mx-auto max-w-3xl px-6 lg:px-12">
    <div class="mb-14 text-center reveal">
      <span class="section-tag">FAQ</span>
      <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
        Preguntas habituales,
        <span class="gradient-text"> respondidas sin rodeos.</span>
      </h2>
    </div>

    <div class="flex flex-col gap-2.5 reveal">
      {faqs.map((faq, i) => (
        <details class="faq-item" data-i={i}>
          <summary class="faq-sum">
            <span class="faq-q">{faq.q}</span>
            <div class="faq-ico">
              <svg class="ico-plus" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 5v14M5 12h14" stroke-linecap="round"/>
              </svg>
              <svg class="ico-minus" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14" stroke-linecap="round"/>
              </svg>
            </div>
          </summary>
          <div class="faq-ans">
            <p class="text-sm leading-relaxed text-white/50">{faq.a}</p>
          </div>
        </details>
      ))}
    </div>

    <div class="mt-10 text-center reveal">
      <p class="text-sm text-white/35">
        ¿Tienes otra duda?
        <a href={WA_URL} target="_blank" rel="noopener noreferrer" class="text-[#4F9EFF]/60 hover:text-[#4F9EFF] transition-colors underline underline-offset-2 ml-1">
          Escríbeme por WhatsApp
        </a>
        y te respondo.
      </p>
    </div>
  </div>
</section>

<style>
  .section-py { padding-top: 7rem; padding-bottom: 7rem; }
  .faq-item {
    background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.07);
    border-radius: 12px; overflow: hidden; transition: border-color 0.2s ease;
  }
  .faq-item[open] { border-color: rgba(79,158,255,0.2); }
  .faq-sum {
    display: flex; align-items: center; justify-content: space-between;
    gap: 1rem; padding: 1.25rem 1.5rem; cursor: pointer; list-style: none; user-select: none;
  }
  .faq-sum::-webkit-details-marker { display: none; }
  .faq-q { font-size: 0.9rem; font-weight: 600; color: rgba(255,255,255,0.8); line-height: 1.4; }
  .faq-ico { flex-shrink: 0; width: 18px; height: 18px; color: rgba(79,158,255,0.4); position: relative; }
  .ico-plus, .ico-minus { position: absolute; inset: 0; transition: opacity 0.2s ease; }
  .ico-minus { opacity: 0; }
  details[open] .ico-plus { opacity: 0; }
  details[open] .ico-minus { opacity: 1; }
  .faq-ans { padding: 0 1.5rem 1.25rem; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 1rem; }
</style>
