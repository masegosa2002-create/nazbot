---
const pasos = [
  {
    num: "01",
    title: "Nos cuentas a quién le vendes",
    desc: "Una llamada de 30 minutos. Sector, tamaño de empresa, zona geográfica, perfil de decisor. Con eso ya tenemos lo que necesitamos.",
    detalle: "30 minutos · Gratuita",
  },
  {
    num: "02",
    title: "Configuramos tu agente",
    desc: "En 72 horas tienes el sistema listo. El agente sabe a quién buscar, cómo analizar si hay encaje y cómo escribir el primer mensaje.",
    detalle: "72 horas de setup",
  },
  {
    num: "03",
    title: "El agente trabaja cada día",
    desc: "Busca empresas, las analiza, les escribe y registra todo. Sin que abras el ordenador. Sin que te acuerdes de nada.",
    detalle: "Automático y continuo",
  },
  {
    num: "04",
    title: "Tú entras solo para cerrar",
    desc: "Cuando hay interés, el sistema te avisa. Entras al panel, ves el contexto completo y actúas. Nada de buscar historial. Nada de improvisar.",
    detalle: "Solo cierras tú",
  },
];
---

<section id="como-funciona" class="section-py relative bg-[#0b0b0b]">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>

  <div class="mx-auto max-w-6xl px-6 lg:px-12">
    <!-- Header -->
    <div class="mb-16 text-center reveal">
      <span class="section-tag">El proceso</span>
      <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-white sm:text-4xl lg:text-5xl">
        De cero a agente funcionando
        <span class="gradient-text"> en 4 pasos.</span>
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-offset">
        Sin meses de implementación. Sin curvas de aprendizaje.
        Lo pones en marcha una vez y funciona solo.
      </p>
    </div>

    <!-- Steps: layout vertical con línea -->
    <div class="relative max-w-3xl mx-auto">
      <!-- Línea vertical (desktop) -->
      <div class="linea-vertical hidden lg:block"></div>

      <div class="flex flex-col gap-0">
        {pasos.map((paso, i) => (
          <div class={`paso-item reveal delay-${(i + 1) * 100} ${i < pasos.length - 1 ? "mb-0" : ""}`}>
            <!-- Número badge + línea -->
            <div class="paso-badge-col">
              <div class="paso-badge">{paso.num}</div>
              {i < pasos.length - 1 && <div class="paso-conector hidden lg:block"></div>}
            </div>

            <!-- Contenido -->
            <div class="paso-body">
              <div class="flex items-start justify-between gap-4 flex-wrap">
                <h3 class="text-lg font-semibold text-white">{paso.title}</h3>
                <span class="paso-detalle">{paso.detalle}</span>
              </div>
              <p class="mt-2 text-sm leading-relaxed text-offset">{paso.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- CTA secundario -->
    <div class="mt-16 text-center reveal">
      <a href="#cta" class="btn-secondary inline-flex">
        Empieza con una llamada gratuita
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .section-py {
    padding-top: 7rem;
    padding-bottom: 7rem;
  }

  .paso-item {
    display: flex;
    gap: 2rem;
    padding-bottom: 2.5rem;
    position: relative;
  }

  .paso-badge-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    width: 3rem;
  }

  .paso-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: rgba(255, 255, 255, 0.5);
    flex-shrink: 0;
  }

  .paso-conector {
    flex: 1;
    width: 1px;
    min-height: 2rem;
    background: linear-gradient(to bottom, rgba(255,255,255,0.08), rgba(255,255,255,0.02));
    margin-top: 0.5rem;
  }

  .linea-vertical {
    position: absolute;
    left: 1.5rem;
    top: 3rem;
    bottom: 3rem;
    width: 1px;
    background: linear-gradient(to bottom, rgba(255,255,255,0.06), rgba(255,255,255,0.01));
  }

  .paso-body {
    flex: 1;
    padding-top: 0.75rem;
  }

  .paso-detalle {
    display: inline-block;
    padding: 0.2rem 0.75rem;
    border-radius: 100px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.07);
    font-size: 0.7rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.4);
    white-space: nowrap;
    flex-shrink: 0;
  }
</style>
