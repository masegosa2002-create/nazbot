---
const WA_URL = "https://wa.me/34659426999?text=SISTEMA";

const planes = [
  {
    nombre: "CORE",
    precio: "2.000€",
    tagline: "El sistema completo para empezar a captar y seguir en automático.",
    features: [
      "WhatsApp + webchat activos",
      "Integración con tu agenda",
      "Panel de control centralizado",
      "Cualificación básica (hasta 5 preguntas)",
      "Seguimiento automático (2/sem · 14 días)",
      "1 semana de estabilización",
      "Loom + diagrama",
      "Garantía 15 días",
    ],
    destacado: false,
  },
  {
    nombre: "PRO",
    precio: "2.500€",
    tagline: "Para negocios con mayor volumen o flujos más complejos.",
    features: [
      "Todo lo de CORE",
      "Cualificación avanzada (sin límite de preguntas)",
      "Segmentación por tipo de lead o servicio",
      "Integración con CRM existente",
      "Seguimiento personalizado por segmento",
      "Panel con etiquetas y filtros avanzados",
      "2 semanas de estabilización",
      "Soporte prioritario durante el sprint",
    ],
    destacado: true,
  },
];
---

<section id="precios" class="section-py relative bg-[#0b0b0b]">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/8 to-transparent"></div>

  <div class="mx-auto max-w-5xl px-6 lg:px-12">
    <div class="mb-16 text-center reveal">
      <span class="section-tag">Precios</span>
      <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-white sm:text-4xl lg:text-5xl">
        Un pago. Un sprint.
        <span class="gradient-text"> Sistema funcionando.</span>
      </h2>
      <p class="mx-auto mt-4 max-w-lg text-base leading-relaxed text-white/50">
        Pagas 50% al inicio y 50% cuando el sistema está funcionando y estabilizado.
      </p>
    </div>

    <div class="grid gap-5 lg:grid-cols-2 reveal">
      {planes.map((plan) => (
        <div class={`plan-card ${plan.destacado ? "plan-pro" : ""}`}>
          {plan.destacado && <div class="plan-popular">Más elegido</div>}

          <div class="plan-head">
            <span class="plan-nombre">{plan.nombre}</span>
            <div class="plan-precio">{plan.precio}</div>
            <p class="plan-tag">{plan.tagline}</p>
          </div>

          <ul class="plan-features">
            {plan.features.map((f) => (
              <li class="plan-feature">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="color:rgba(79,158,255,0.5)">
                  <path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span class="text-sm text-white/60">{f}</span>
              </li>
            ))}
          </ul>

          <div class="plan-cta">
            <a href={WA_URL} target="_blank" rel="noopener noreferrer" class={plan.destacado ? "btn-accent w-full justify-center" : "btn-secondary w-full justify-center"}>
              Escríbeme por WhatsApp
            </a>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-8 text-center reveal">
      <p class="text-sm text-white/35">
        Pago: <strong class="text-white/55">50% al inicio · 50% al entregar</strong> · Transferencia o Bizum
      </p>
    </div>

    <div class="diagnostico-nota mt-6 reveal">
      <p class="text-sm text-white/40 text-center">
        <strong class="text-white/55">¿Tu caso es complejo o no tienes claro si encaja?</strong><br/>
        Puedo hacer un diagnóstico previo (250€, descontable si contratas el sprint). Cuéntamelo por DM.
      </p>
    </div>
  </div>
</section>

<style>
  .plan-card {
    background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px; overflow: hidden; display: flex; flex-direction: column;
    transition: border-color 0.2s ease;
  }
  .plan-card:hover { border-color: rgba(255,255,255,0.14); }
  .plan-pro { border-color: rgba(79,158,255,0.2); background: rgba(79,158,255,0.02); }
  .plan-pro:hover { border-color: rgba(79,158,255,0.3); }
  .plan-popular {
    background: rgba(79,158,255,0.08); border-bottom: 1px solid rgba(79,158,255,0.15);
    text-align: center; font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em;
    text-transform: uppercase; color: rgba(79,158,255,0.7); padding: 0.45rem;
  }
  .plan-head { padding: 1.75rem 1.75rem 1.25rem; border-bottom: 1px solid rgba(255,255,255,0.05); }
  .plan-nombre { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(79,158,255,0.5); }
  .plan-precio { font-size: 2.75rem; font-weight: 800; letter-spacing: -0.04em; color: rgba(255,255,255,0.9); line-height: 1.1; margin: 0.5rem 0 0.75rem; }
  .plan-tag { font-size: 0.8rem; color: rgba(255,255,255,0.38); line-height: 1.4; }
  .plan-features { list-style: none; padding: 1.5rem 1.75rem; display: flex; flex-direction: column; gap: 0.75rem; flex: 1; }
  .plan-feature { display: flex; align-items: flex-start; gap: 0.625rem; }
  .plan-cta { padding: 1.25rem 1.75rem 1.75rem; }
  .diagnostico-nota {
    padding: 1.25rem 1.5rem;
    background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.06);
    border-radius: 10px;
  }
</style>
