---
const WA_URL = "https://wa.me/34659426999?text=SISTEMA";

const pasos = [
  { num: "01", title: "Me escribes", desc: "Escríbeme 'SISTEMA' por WhatsApp. Es la señal de que quieres información.", tag: "WhatsApp" },
  { num: "02", title: "Vemos el encaje", desc: "Llamada corta de 20 minutos. Te pregunto sobre tu negocio y te digo si el sistema tiene sentido para ti.", tag: "20 min · Gratis" },
  { num: "03", title: "Recibo accesos y material", desc: "Me das acceso a WhatsApp Business, web y agenda. Aquí empieza el sprint. Sin reuniones interminables.", tag: "1–2h de tu tiempo" },
  { num: "04", title: "Monto el sprint", desc: "Configuro, pruebo y ajusto. Tú no tienes que hacer nada salvo responder alguna duda puntual.", tag: "10–14 días" },
  { num: "05", title: "Estabilizamos", desc: "1 semana de prueba real. Si algo falla o necesita ajuste, lo corrijo sin coste adicional.", tag: "Garantía 15 días" },
  { num: "06", title: "Te entrego el sistema explicado", desc: "Vídeo Loom del sistema completo + diagrama para tu equipo. El sistema funciona solo desde ese momento.", tag: "Loom + diagrama" },
];

const reglas = [
  "Plazo: 10–14 días desde que recibo accesos",
  "Si faltan accesos, el proyecto se pausa",
  "Soporte en horario laboral (respuesta mismo día)",
  "Todo lo fuera de alcance se valora aparte",
];
---

<section id="proceso" class="section-py relative bg-[#0d0d0d]">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/8 to-transparent"></div>

  <div class="mx-auto max-w-5xl px-6 lg:px-12">
    <div class="mb-16 text-center reveal">
      <span class="section-tag">Cómo trabajamos</span>
      <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-white sm:text-4xl lg:text-5xl">
        De DM a sistema activo
        <span class="gradient-text"> en 6 pasos.</span>
      </h2>
    </div>

    <div class="relative max-w-2xl mx-auto">
      {pasos.map((p, i) => (
        <div class={`paso-row reveal delay-${Math.min((i + 1) * 100, 500)}`}>
          <div class="paso-left">
            <div class="paso-badge">{p.num}</div>
            {i < pasos.length - 1 && <div class="paso-linea"></div>}
          </div>
          <div class="paso-right">
            <div class="paso-top">
              <h3 class="text-base font-semibold text-white">{p.title}</h3>
              <span class="paso-tag">{p.tag}</span>
            </div>
            <p class="mt-2 text-sm leading-relaxed text-white/48">{p.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Reglas -->
    <div class="reglas-box mt-14 reveal">
      <p class="reglas-title">Reglas del juego</p>
      <div class="grid gap-2 sm:grid-cols-2">
        {reglas.map((r) => (
          <div class="regla-item">
            <div class="regla-dot"></div>
            <span class="text-sm text-white/50">{r}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="mt-12 text-center reveal">
      <a href={WA_URL} target="_blank" rel="noopener noreferrer" class="btn-accent">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.867-2.031-.967-.272-.099-.47-.148-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/>
        </svg>
        Empezar — escríbeme por WhatsApp
      </a>
    </div>
  </div>
</section>

<style>
  .paso-row { display: flex; gap: 1.5rem; }
  .paso-left { display: flex; flex-direction: column; align-items: center; width: 3rem; flex-shrink: 0; }
  .paso-badge {
    display: flex; align-items: center; justify-content: center;
    width: 3rem; height: 3rem; border-radius: 50%;
    background: rgba(79,158,255,0.05); border: 1px solid rgba(79,158,255,0.2);
    font-size: 0.65rem; font-weight: 700; letter-spacing: 0.06em; color: rgba(79,158,255,0.6);
    flex-shrink: 0;
  }
  .paso-linea {
    flex: 1; width: 1px; min-height: 1.25rem;
    background: linear-gradient(to bottom, rgba(79,158,255,0.15), rgba(79,158,255,0.02));
    margin: 0.375rem 0;
  }
  .paso-right { flex: 1; padding-top: 0.75rem; padding-bottom: 2.25rem; }
  .paso-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
  .paso-tag {
    display: inline-block; padding: 0.18rem 0.625rem; border-radius: 100px;
    background: rgba(79,158,255,0.05); border: 1px solid rgba(79,158,255,0.12);
    font-size: 0.68rem; font-weight: 600; color: rgba(79,158,255,0.5);
    white-space: nowrap; flex-shrink: 0; margin-top: 0.15rem;
  }
  .reglas-box {
    padding: 1.5rem 2rem;
    background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.07);
    border-radius: 12px;
  }
  .reglas-title { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(255,255,255,0.25); margin-bottom: 1rem; }
  .regla-item { display: flex; align-items: flex-start; gap: 0.625rem; padding: 0.375rem 0; }
  .regla-dot { width: 5px; height: 5px; border-radius: 50%; background: rgba(255,255,255,0.2); margin-top: 0.45rem; flex-shrink: 0; }
</style>
