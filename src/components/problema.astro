---
const dolores = [
  {
    title: "Llegas tarde",
    desc: "El lead pregunta. Tú contestas horas después. Ya eligió a otro.",
    svg: `<path d="M12 6v6l4 2"/><circle cx="12" cy="12" r="10"/>`,
  },
  {
    title: "El seguimiento no ocurre",
    desc: "\"Luego les escribo\" es la frase que más ventas ha matado. Ese mensaje nunca llega.",
    svg: `<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>`,
  },
  {
    title: "Nadie sabe qué está pasando",
    desc: "Los leads viven repartidos entre WhatsApp, formularios y notas de voz. Sin orden, sin control.",
    svg: `<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>`,
  },
  {
    title: "Tu equipo apaga fuegos",
    desc: "Responden lo urgente, olvidan lo importante. Con más volumen, el problema solo crece.",
    svg: `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
  },
];
---

<section id="problema" class="section-py relative bg-[#0d0d0d]">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/8 to-transparent"></div>

  <div class="mx-auto max-w-6xl px-6 lg:px-12">
    <div class="mb-16 max-w-3xl reveal">
      <span class="section-tag">El problema</span>
      <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-white sm:text-4xl lg:text-5xl">
        No pierdes leads por falta de interés.
        <span class="gradient-text"> Los pierdes por falta de sistema.</span>
      </h2>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 reveal">
      {dolores.map((d, i) => (
        <div class={`dolor-card reveal delay-${(i + 1) * 100}`}>
          <div class="dolor-ico">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={d.svg}></svg>
          </div>
          <div>
            <h3 class="dolor-title">{d.title}</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-white/45">{d.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 cierre-box reveal">
      <p class="text-sm leading-relaxed text-white/60">
        Nazbot monta el sistema para que captar, responder y seguir
        <strong class="text-white/80"> no dependa de la memoria ni del caos del día a día.</strong>
      </p>
    </div>
  </div>
</section>

<style>
  .dolor-card {
    display: flex; align-items: flex-start; gap: 1.25rem;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 14px; padding: 1.75rem;
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .dolor-card:hover {
    border-color: rgba(79,158,255,0.14);
    background: rgba(79,158,255,0.02);
  }
  .dolor-ico {
    display: flex; align-items: center; justify-content: center;
    width: 36px; height: 36px; flex-shrink: 0;
    border-radius: 9px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.35);
  }
  .dolor-title {
    font-size: 0.95rem; font-weight: 700; color: rgba(255,255,255,0.85);
  }
  .cierre-box {
    padding: 1.5rem 2rem;
    background: rgba(79,158,255,0.04);
    border: 1px solid rgba(79,158,255,0.12);
    border-radius: 12px;
  }
</style>
