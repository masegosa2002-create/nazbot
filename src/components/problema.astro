---
import { Icon } from "astro-icon/components";

const problemas = [
  {
    icon: "mdi:folder-alert-outline",
    title: "Sin orden ni criterio",
    desc: "Buscas clientes a mano, sin un proceso claro. Sin sistema, muchos pasan delante de ti y no te enteras.",
  },
  {
    icon: "mdi:robot-outline",
    title: "Captación de oportunidades",
    desc: "Tu agente busca y escribe el primer mensaje por ti. Tú le dices qué tipo de cliente quieres. Él lo encuentra y lo contacta solo.",
  },
  {
    icon: "mdi:view-dashboard-outline",
    title: "Control en el dashboard",
    desc: "En tu panel ves en un vistazo quién está esperando respuesta y quién ya fue contactado. Todo ordenado, sin buscar en ningún sitio.",
  },
  {
    icon: "mdi:trending-up",
    title: "Sin fricción, sin fugas",
    desc: "El agente sigue trabajando aunque tú estés ocupado. No se olvida de nadie. No descansa. No comete errores por cansancio.",
  },
];
---

<section id="problema" class="section-py relative bg-[#0b0b0b]">
  <!-- Subtle top border -->
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>

  <div class="mx-auto max-w-6xl px-6 lg:px-12">
    <!-- Header -->
    <div class="mb-16 text-center reveal">
      <span class="section-tag">Qué hace NazBot</span>
      <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-white sm:text-4xl lg:text-5xl">
        Tu agente trabaja.
        <span class="gradient-text"> Tú cierras.</span>
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-offset">
        NazBot hace por ti todo lo que normalmente consumes horas haciendo a mano:
        buscar, contactar, organizar y hacer seguimiento.
      </p>
    </div>

    <!-- Cards grid -->
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {
        problemas.map((p, i) => (
          <div class={`card reveal delay-${(i + 1) * 100}`}>
            <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-lg border border-white/8 bg-white/4">
              <Icon name={p.icon} class="h-5 w-5 text-offset" />
            </div>
            <h3 class="mb-2 text-base font-semibold text-white">{p.title}</h3>
            <p class="text-sm leading-relaxed text-offset">{p.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .section-py {
    padding-top: 7rem;
    padding-bottom: 7rem;
  }
  .bg-white\/4 {
    background: rgba(255,255,255,0.04);
  }
  .border-white\/8 {
    border-color: rgba(255,255,255,0.08);
  }
</style>
