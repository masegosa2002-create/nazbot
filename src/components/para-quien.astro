---
const encaja = [
  "Vendes a otras empresas (B2B)",
  "Buscas clientes de forma manual o sin sistema claro",
  "Tu ticket medio es alto y cada cliente importa",
  "Quieres más reuniones sin contratar un comercial",
  "Tienes poco tiempo para prospectar y aun así necesitas crecer",
];

const noEncaja = [
  "Vendes directamente a consumidores (B2C)",
  "Ya tienes un equipo de ventas y CRM funcionando",
  "Buscas resultados sin ningún tipo de llamada o proceso",
];
---

<section id="para-quien" class="section-py relative bg-[#0b0b0b]">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>

  <div class="mx-auto max-w-6xl px-6 lg:px-12">
    <!-- Header -->
    <div class="mb-16 text-center reveal">
      <span class="section-tag">¿Es para ti?</span>
      <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-white sm:text-4xl lg:text-5xl">
        Funciona si vendes a empresas
        <span class="gradient-text"> y prospectas a mano.</span>
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-offset">
        No somos para todos. Si cumples esto, tiene sentido hablar.
      </p>
    </div>

    <div class="grid gap-6 lg:grid-cols-2">

      <!-- Encaja -->
      <div class="filtro-card reveal">
        <div class="filtro-header encaja-header">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="text-sm font-semibold text-white/80">Tiene sentido para ti si...</span>
        </div>
        <ul class="filtro-lista">
          {encaja.map((item) => (
            <li class="filtro-item">
              <div class="filtro-dot encaja-dot"></div>
              <span class="text-sm text-white/70">{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- No encaja -->
      <div class="filtro-card reveal delay-100">
        <div class="filtro-header noencaja-header">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M18 6L6 18M6 6l12 12" stroke-linecap="round"/>
          </svg>
          <span class="text-sm font-semibold text-white/40">Probablemente no encaja si...</span>
        </div>
        <ul class="filtro-lista">
          {noEncaja.map((item) => (
            <li class="filtro-item">
              <div class="filtro-dot noencaja-dot"></div>
              <span class="text-sm text-offset/40">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- CTA inline -->
    <div class="mt-14 text-center reveal">
      <p class="mb-6 text-offset">
        ¿No sabes si es para ti? Cuéntame tu situación y te digo en 24h si tiene sentido.
      </p>
      <a href="#cta" class="btn-primary inline-flex px-8 py-3.5">
        Hablar con David
      </a>
    </div>
  </div>
</section>

<style>
  .section-py {
    padding-top: 7rem;
    padding-bottom: 7rem;
  }

  .filtro-card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 14px;
    overflow: hidden;
  }

  .filtro-header {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .encaja-header {
    background: rgba(255, 255, 255, 0.03);
    color: rgba(255, 255, 255, 0.6);
  }

  .noencaja-header {
    background: transparent;
    color: rgba(255, 255, 255, 0.25);
  }

  .filtro-lista {
    list-style: none;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .filtro-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .filtro-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    margin-top: 0.45rem;
    flex-shrink: 0;
  }

  .encaja-dot {
    background: rgba(255, 255, 255, 0.4);
  }

  .noencaja-dot {
    background: rgba(255, 255, 255, 0.12);
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #fff;
    color: #0b0b0b;
    font-weight: 700;
    border-radius: 8px;
    text-decoration: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .btn-primary:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }
</style>
