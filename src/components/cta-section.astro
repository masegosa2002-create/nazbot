---
---

<section id="cta" class="section-py relative overflow-hidden bg-[#0f0f0f]">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>

  <!-- Ambient glow -->
  <div
    class="pointer-events-none absolute left-1/2 top-0 h-96 w-96 -translate-x-1/2 rounded-full opacity-15"
    style="background: radial-gradient(circle, rgba(255,255,255,0.12) 0%, transparent 70%);"
  ></div>

  <div class="relative mx-auto max-w-2xl px-6 text-center lg:px-12">
    <div class="reveal">
      <span class="section-tag">Gratis y sin compromisos</span>
      <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-white sm:text-4xl lg:text-5xl">
        Hablamos 30 minutos
        <span class="gradient-text"> y te lo explico todo</span>
      </h2>
      <p class="mx-auto mt-4 max-w-lg text-base leading-relaxed text-offset">
        Me cuentas cómo buscas clientes ahora mismo y yo te digo si NazBot
        tiene sentido para tu negocio. Sin tecnicismos, sin presión.
      </p>
    </div>

    <!-- Form -->
    <form
      id="lead-form"
      class="reveal delay-200 mt-10 text-left"
      novalidate
    >
      <div class="grid gap-4 sm:grid-cols-2">
        <div class="form-group">
          <label for="nombre" class="form-label">Nombre</label>
          <input
            type="text"
            id="nombre"
            name="nombre"
            class="form-input"
            placeholder="Tu nombre"
            required
          />
        </div>
        <div class="form-group">
          <label for="email" class="form-label">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            class="form-input"
            placeholder="tu@email.com"
            required
          />
        </div>
        <div class="form-group sm:col-span-2">
          <label for="tipo-negocio" class="form-label">Tipo de negocio</label>
          <select id="tipo-negocio" name="tipo" class="form-input" required>
            <option value="" disabled selected>Selecciona una opción</option>
            <option value="autonomo">Autónomo / Freelance</option>
            <option value="agencia">Agencia</option>
            <option value="consultor">Consultor / Asesor</option>
            <option value="b2b">Negocio B2B</option>
            <option value="otro">Otro</option>
          </select>
        </div>
        <div class="form-group sm:col-span-2">
          <label for="mensaje" class="form-label">
            Cuéntame brevemente tu situación
          </label>
          <textarea
            id="mensaje"
            name="mensaje"
            class="form-input"
            rows="4"
            placeholder="¿Cómo buscas clientes ahora? ¿Cuál es tu mayor problema?"
            required
          ></textarea>
        </div>
      </div>

      <div class="mt-6 flex flex-col items-center gap-4">
        <button type="submit" class="btn-primary w-full justify-center sm:w-auto sm:px-12">
          Quiero mi llamada gratuita
        </button>
        <p class="text-xs text-offset/50">
          Sin spam. Sin presión. Solo te cuento si puedo ayudarte.
        </p>
      </div>
    </form>

    <!-- Success message (hidden by default) -->
    <div id="form-success" class="reveal mt-10 hidden text-center">
      <div class="success-card mx-auto max-w-sm">
        <div class="mb-3 text-3xl">✓</div>
        <h3 class="text-lg font-bold text-white">¡Solicitud enviada!</h3>
        <p class="mt-2 text-sm text-offset">
          Te escribiré en menos de 24 horas para coordinar la llamada.
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("lead-form") as HTMLFormElement;

  form?.addEventListener("submit", (e) => {
    e.preventDefault();

    const nombre = (document.getElementById("nombre") as HTMLInputElement).value.trim();
    const email = (document.getElementById("email") as HTMLInputElement).value.trim();
    const tipo = (document.getElementById("tipo-negocio") as HTMLSelectElement).value;
    const mensaje = (document.getElementById("mensaje") as HTMLTextAreaElement).value.trim();

    const texto = [
      `Hola David, vengo de nazbot.space 👋`,
      ``,
      `*Nombre:* ${nombre}`,
      `*Email:* ${email}`,
      `*Tipo de negocio:* ${tipo}`,
      `*Situación:* ${mensaje}`,
    ].join("\n");

    const url = `https://wa.me/34659426999?text=${encodeURIComponent(texto)}`;
    window.open(url, "_blank");
  });
</script>

<style>
  .section-py {
    padding-top: 7rem;
    padding-bottom: 7rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .form-label {
    font-size: 0.8rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.6);
    letter-spacing: 0.01em;
  }

  .success-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 2rem;
    color: rgba(255, 255, 255, 0.7);
  }
</style>
