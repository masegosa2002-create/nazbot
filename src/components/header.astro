---
import { Icon } from "astro-icon/components";
import type { NavItem } from "~/types";

const navItems: Array<NavItem> = [
  { title: "Cómo funciona", url: "#como-funciona" },
  { title: "Sprint", url: "#sprint" },
  { title: "Demos", url: "#demos" },
  { title: "FAQ", url: "#faq" },
];
---

<header
  id="page-header"
  class="fixed top-0 z-50 w-full border-b border-transparent px-5 py-3 transition-all duration-300 sm:px-8 lg:px-12"
>
  <div class="mx-auto flex max-w-6xl items-center justify-between">

    <!-- Logo -->
    <a href="#" class="flex items-center gap-2 no-underline">
      <div class="flex h-8 w-8 items-center justify-center rounded-md border border-white/20 bg-white/5">
        <span class="text-xs font-bold tracking-widest text-white">NB</span>
      </div>
      <span class="text-sm font-semibold tracking-tight text-white">
        Naz<span class="text-offset">Bot</span>
      </span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:block">
      <ul class="flex items-center gap-7">
        {navItems.map(({ title, url }) => (
          <li>
            <a
              class="text-sm font-medium text-offset no-underline transition-colors hover:text-white"
              href={url}
            >
              {title}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Desktop CTA -->
    <a href="https://wa.me/34659426999?text=SISTEMA" target="_blank" rel="noopener noreferrer" class="btn-accent hidden text-sm md:inline-flex">
      Escríbeme por WhatsApp
    </a>

    <!-- Mobile hamburger -->
    <button
      id="open-nav-button"
      type="button"
      class="flex h-9 w-9 items-center justify-center rounded-md border border-white/10 bg-white/5 md:hidden"
      aria-label="Abrir menú"
    >
      <Icon name="mdi:menu" class="size-5 text-white" />
    </button>
  </div>
</header>

<!-- Mobile menu overlay -->
<div id="menu-modal" class="modal hidden" aria-hidden="true">
  <div class="fixed inset-0 z-[60] flex flex-col bg-[#0b0b0b]">

    <!-- Modal header -->
    <div class="flex items-center justify-between border-b border-white/[0.07] px-5 py-4">
      <div class="flex items-center gap-2">
        <div class="flex h-7 w-7 items-center justify-center rounded-md border border-white/20 bg-white/5">
          <span class="text-xs font-bold tracking-widest text-white">NB</span>
        </div>
        <span class="text-sm font-semibold text-white">NazBot</span>
      </div>
      <button
        id="close-nav-button"
        type="button"
        class="flex h-9 w-9 items-center justify-center rounded-md border border-white/10 bg-white/5"
        aria-label="Cerrar menú"
      >
        <Icon name="mdi:close" class="size-5 text-white" />
      </button>
    </div>

    <!-- Nav links -->
    <nav class="flex-1 overflow-y-auto px-5 py-6" role="dialog" aria-modal="true">
      <ul class="flex flex-col gap-1">
        {navItems.map(({ title, url }) => (
          <li>
            <a
              class="flex items-center rounded-lg px-4 py-4 text-base font-medium text-white/80 no-underline transition-colors hover:bg-white/5 hover:text-white"
              href={url}
            >
              {title}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Bottom CTA -->
    <div class="border-t border-white/[0.07] px-5 py-5">
      <a href="https://wa.me/34659426999?text=SISTEMA" target="_blank" rel="noopener noreferrer" class="btn-accent w-full justify-center text-base">
        Escríbeme por WhatsApp
      </a>
      <p class="mt-3 text-center text-xs text-offset/50">Sin compromiso · Respondo en &lt; 24h</p>
    </div>

  </div>
</div>

<script>
  import MicroModal from "micromodal";
  import invariant from "tiny-invariant";

  const menuModalId = "menu-modal";
  const header = document.querySelector("#page-header") as HTMLElement;
  const page = document.documentElement;
  const menu = document.querySelector(`#${menuModalId} nav`);
  const openNavButton = document.querySelector("#open-nav-button");
  const closeNavButton = document.querySelector("#close-nav-button");

  invariant(header, "header should not be null");
  invariant(menu, "menu should not be null");
  invariant(openNavButton, "openNavButton should not be null");
  invariant(closeNavButton, "closeNavButton should not be null");

  const openMenu = () => MicroModal.show(menuModalId, { disableScroll: true });
  const closeMenu = () => MicroModal.close(menuModalId);

  openNavButton.addEventListener("click", openMenu);
  closeNavButton.addEventListener("click", closeMenu);

  document.addEventListener("scroll", () => {
    const scrolled = page.scrollTop > 20;
    header.classList.toggle("scrolled-header", scrolled);
  });

  menu.addEventListener("click", (event) => {
    if ((event.target as HTMLElement).tagName === "A") {
      closeMenu();
    }
  });
</script>

<noscript>
  <style>
    #open-nav-button { display: none; }
  </style>
</noscript>

<style>
  .scrolled-header {
    background: rgba(11, 11, 11, 0.95);
    backdrop-filter: blur(12px);
    border-bottom-color: rgba(255, 255, 255, 0.07);
  }

  .modal.is-open {
    display: block;
  }

  a {
    text-decoration: none;
  }
</style>
