---
import Starfield from "~/components/starfield.astro";
---

<section class="hero relative flex min-h-screen items-center overflow-hidden bg-[#0b0b0b]">
  <!-- Starfield canvas (sutil, opacidad reducida) -->
  <div class="absolute inset-0 opacity-20">
    <Starfield />
  </div>

  <!-- Grid pattern overlay -->
  <div class="absolute inset-0 grid-pattern opacity-60"></div>

  <!-- Radial glow central -->
  <div
    class="pointer-events-none absolute left-1/2 top-1/2 h-[600px] w-[600px] -translate-x-1/2 -translate-y-1/2 rounded-full"
    style="background: radial-gradient(circle, rgba(255,255,255,0.04) 0%, transparent 70%);"
  >
  </div>

  <div class="relative z-10 mx-auto w-full max-w-7xl px-6 py-20 lg:py-32 lg:px-12">
    <div class="grid items-center gap-16 lg:grid-cols-2">
      <!-- Left: Copy -->
      <div class="flex flex-col gap-8">
        <div>
          <span class="section-tag">Tu agente de ventas personal</span>
        </div>

        <h1
          class="text-3xl font-extrabold leading-[1.1] tracking-tight text-white sm:text-5xl lg:text-6xl"
        >
          Encuentra clientes y
          <span class="gradient-text"> contacta por ti solo</span>
        </h1>

        <p class="max-w-lg text-base leading-relaxed text-offset sm:text-lg">
          NazBot pone un agente a trabajar para ti: busca clientes, los ordena
          por interés y escribe el primer mensaje. Tú solo decides a quién cerrar.
        </p>

        <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
          <a href="#cta" class="btn-primary justify-center">
            Quiero mi agente
          </a>
          <a href="#como-funciona" class="btn-secondary">
            Ver cómo funciona
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M12 5v14M5 12l7 7 7-7"></path>
            </svg>
          </a>
        </div>

        <p class="text-xs text-offset/60">
          Gratis &nbsp;·&nbsp; 30 minutos &nbsp;·&nbsp; Sin compromisos
        </p>
      </div>

      <!-- Right: Dashboard preview flotante -->
      <div class="hero-visual relative hidden lg:block">
        <!-- Outer glow -->
        <div
          class="absolute -inset-8 rounded-2xl opacity-30"
          style="background: radial-gradient(ellipse, rgba(255,255,255,0.06) 0%, transparent 70%);"
        >
        </div>

        <div class="relative flex flex-col gap-4">
          <!-- Mini card: score top -->
          <div class="hero-card float-card-1 ml-auto w-64">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-xs text-offset">Oportunidad detectada</p>
                <p class="mt-0.5 text-sm font-semibold text-white">
                  Ana García — Agencia Norte
                </p>
              </div>
              <div
                class="flex h-10 w-10 items-center justify-center rounded-full border border-white/10 bg-white/5 text-xs font-bold text-white"
              >
                92
              </div>
            </div>
            <div class="mt-3 flex items-center gap-2">
              <div class="h-1.5 flex-1 rounded-full bg-white/10">
                <div
                  class="h-1.5 rounded-full bg-white"
                  style="width: 92%"
                ></div>
              </div>
              <span class="text-xs text-offset">Score alto</span>
            </div>
          </div>

          <!-- Main dashboard card -->
          <div class="hero-card">
            <div class="mb-4 flex items-center justify-between">
              <p class="text-sm font-semibold text-white">
                Pipeline activo
              </p>
              <span
                class="rounded-full bg-white/5 px-2 py-0.5 text-xs text-offset"
                >Esta semana</span
              >
            </div>
            <div class="grid grid-cols-3 gap-3">
              <div class="rounded-lg bg-white/5 p-3 text-center">
                <p class="text-xl font-bold text-white">12</p>
                <p class="text-xs text-offset">Leads activos</p>
              </div>
              <div class="rounded-lg bg-white/5 p-3 text-center">
                <p class="text-xl font-bold text-white">4</p>
                <p class="text-xs text-offset">Calientes</p>
              </div>
              <div class="rounded-lg bg-white/5 p-3 text-center">
                <p class="text-xl font-bold text-white">3</p>
                <p class="text-xs text-offset">Pendientes</p>
              </div>
            </div>

            <div class="mt-4 flex flex-col gap-2">
              {
                [
                  { name: "Ana García", score: 92, pct: "92%" },
                  { name: "Luis Pérez", score: 78, pct: "78%" },
                  { name: "Marta Ruiz", score: 61, pct: "61%" },
                ].map((item) => (
                  <div class="flex items-center gap-3">
                    <div class="w-24 truncate text-xs text-white">
                      {item.name}
                    </div>
                    <div class="h-1 flex-1 rounded-full bg-white/10">
                      <div
                        class="h-1 rounded-full bg-white/70"
                        style={`width: ${item.pct}`}
                      />
                    </div>
                    <span class="w-6 text-right text-xs text-offset">
                      {item.score}
                    </span>
                  </div>
                ))
              }
            </div>
          </div>

          <!-- Mini card: acción sugerida -->
          <div class="hero-card float-card-2 w-72">
            <div class="flex items-start gap-3">
              <div
                class="mt-0.5 flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-md border border-white/10 bg-white/5"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-3.5 w-3.5 text-white"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </div>
              <div>
                <p class="text-xs font-semibold text-white">Acción sugerida</p>
                <p class="mt-0.5 text-xs leading-relaxed text-offset">
                  Envía propuesta a Ana García hoy — lleva 5 días sin contacto.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce opacity-30"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="h-5 w-5 text-white"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
    >
      <path d="M12 5v14M5 12l7 7 7-7" stroke-linecap="round" stroke-linejoin="round"
      ></path>
    </svg>
  </div>
</section>

<style>
  .hero-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 1rem 1.25rem;
    backdrop-filter: blur(10px);
  }

  .float-card-1 {
    animation: floatA 4s ease-in-out infinite alternate;
  }

  .float-card-2 {
    animation: floatB 5s ease-in-out infinite alternate;
  }

  @keyframes floatA {
    from { transform: translateY(0px); }
    to   { transform: translateY(-8px); }
  }

  @keyframes floatB {
    from { transform: translateY(-4px); }
    to   { transform: translateY(6px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .float-card-1,
    .float-card-2 {
      animation: none;
    }
  }
</style>
