---
import Starfield from "~/components/starfield.astro";

const IG_URL = "https://www.instagram.com/nazbot.es/";
---

<section class="hero relative flex min-h-screen items-center overflow-hidden bg-[#0b0b0b]">
  <div class="absolute inset-0 opacity-15">
    <Starfield />
  </div>
  <div class="absolute inset-0 grid-pattern opacity-40"></div>
  <div
    class="pointer-events-none absolute left-1/2 top-1/2 h-[800px] w-[800px] -translate-x-1/2 -translate-y-1/2 rounded-full"
    style="background: radial-gradient(circle, rgba(255,255,255,0.025) 0%, transparent 65%);"
  ></div>

  <div class="relative z-10 mx-auto w-full max-w-5xl px-6 pb-16 pt-28 lg:px-12 lg:pb-24 lg:pt-44">
    <div class="flex flex-col items-center text-center gap-7 max-w-4xl mx-auto">

      <!-- Badge -->
      <div class="hero-badge">
        <span class="badge-dot"></span>
        <span>Sistema comercial con IA · Sprint 10–14 días</span>
      </div>

      <!-- H1 -->
      <h1 class="text-4xl font-extrabold leading-[1.07] tracking-tight text-white sm:text-5xl lg:text-[4rem]">
        Tu negocio pierde leads cada día
        <span class="gradient-text"> porque no tiene sistema.</span>
      </h1>

      <!-- Subheadline -->
      <p class="max-w-2xl text-base leading-relaxed text-offset sm:text-lg">
        Instalamos agentes empresariales que responden, cualifican y agendan automáticamente.
        En 10–14 días tienes el sistema funcionando. Tú solo apareces a cerrar.
      </p>

      <!-- 3 bullets -->
      <div class="bullets-grid">
        {[
          "Seguimiento automático de todos tus leads sin depender de tu equipo",
          "Citas agendadas sin intervención manual desde WhatsApp o tu web",
          "Registro y control de todo en un panel claro — sin hojas de cálculo",
        ].map((b) => (
          <div class="bullet-item">
            <div class="bullet-check">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <span class="text-sm text-white/70">{b}</span>
          </div>
        ))}
      </div>

      <!-- CTAs -->
      <div class="flex flex-col items-center gap-4 mt-2 w-full sm:flex-row sm:justify-center">
        <a href={IG_URL} target="_blank" rel="noopener noreferrer" class="cta-primary">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
          </svg>
          Escríbeme 'SISTEMA' por DM
        </a>
        <a href="#demos" class="cta-secondary">
          Ver demo
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 5v14M5 12l7 7 7-7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <p class="text-xs text-offset/40">Sin compromiso · Respondo en menos de 24h</p>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce opacity-20">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M12 5v14M5 12l7 7 7-7" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
  </div>
</section>

<style>
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 1rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 0.01em;
  }

  .badge-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.4);
    animation: pulse 2.5s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 1; }
  }

  .bullets-grid {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 36rem;
    text-align: left;
  }

  .bullet-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .bullet-check {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    flex-shrink: 0;
    margin-top: 0.05rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .cta-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background: #fff;
    color: #0b0b0b;
    font-weight: 700;
    font-size: 0.95rem;
    padding: 0.875rem 1.75rem;
    border-radius: 8px;
    text-decoration: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
    white-space: nowrap;
  }

  .cta-primary:hover {
    opacity: 0.92;
    transform: translateY(-1px);
  }

  .cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    padding: 0.875rem 1rem;
    transition: color 0.2s ease;
  }

  .cta-secondary:hover {
    color: rgba(255, 255, 255, 0.85);
  }
</style>
