---
const demos = [
  {
    badge: "Demo 1",
    sector: "Clínica estética",
    tagline: "Del anuncio a la cita sin intervención humana",
    pasos: [
      "Lead llega por anuncio o web",
      "Respuesta automática por WhatsApp en segundos",
      "Cualificación: tratamiento, disponibilidad, intención",
      "Reserva de cita directamente desde el chat",
      "Seguimiento automático si no responde",
    ],
    resultados: [
      "Más citas recuperadas",
      "Menos leads perdidos",
      "Menos carga para recepción",
    ],
  },
  {
    badge: "Demo 2",
    sector: "Empresa de servicios",
    tagline: "Del formulario a la llamada de cierre en automático",
    pasos: [
      "Lead entra por formulario o llamada perdida",
      "Se registra y clasifica automáticamente",
      "Cualificación: sector, necesidad, urgencia",
      "Se agenda llamada o presupuesto en el calendario",
      "Seguimiento: 2 recordatorios antes de la llamada",
    ],
    resultados: [
      "Más orden comercial",
      "Más seguimiento completado",
      "Menos oportunidades olvidadas",
    ],
  },
];
---

<section id="demos" class="section-py relative bg-[#0d0d0d]">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/8 to-transparent"></div>

  <div class="mx-auto max-w-6xl px-6 lg:px-12">
    <div class="mb-16 text-center reveal">
      <span class="section-tag">Demos</span>
      <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-white sm:text-4xl lg:text-5xl">
        Dos ejemplos de
        <span class="gradient-text"> cómo se aplica</span>
      </h2>
    </div>

    <div class="grid gap-6 lg:grid-cols-2">
      {demos.map((demo, di) => (
        <div class={`demo-card reveal delay-${(di + 1) * 100}`}>
          <div class="demo-head">
            <span class="demo-badge">{demo.badge}</span>
            <h3 class="demo-sector">{demo.sector}</h3>
            <p class="demo-tag">{demo.tagline}</p>
          </div>

          <div class="demo-body">
            <p class="body-label">Lo que pasa</p>
            <div class="pasos-lista">
              {demo.pasos.map((p, pi) => (
                <div class="paso-item">
                  <span class="paso-num">{String(pi + 1).padStart(2,"0")}</span>
                  <span class="text-sm text-white/65">{p}</span>
                </div>
              ))}
            </div>
          </div>

          <div class="demo-resultados">
            <p class="body-label">Resultado esperado</p>
            <div class="flex flex-col gap-2">
              {demo.resultados.map((r) => (
                <div class="resultado-item">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="color:#4F9EFF">
                    <path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span class="text-sm text-white/65">{r}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section-py { padding-top: 7rem; padding-bottom: 7rem; }
  .demo-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px; overflow: hidden;
    display: flex; flex-direction: column;
    transition: border-color 0.2s ease;
  }
  .demo-card:hover { border-color: rgba(79,158,255,0.18); }
  .demo-head {
    padding: 1.75rem 1.75rem 1.25rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    background: rgba(255,255,255,0.015);
  }
  .demo-badge {
    display: inline-block; margin-bottom: 0.75rem;
    font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
    color: rgba(79,158,255,0.6); background: rgba(79,158,255,0.06);
    border: 1px solid rgba(79,158,255,0.15); border-radius: 100px; padding: 0.2rem 0.625rem;
  }
  .demo-sector { font-size: 1.2rem; font-weight: 700; color: rgba(255,255,255,0.9); margin-bottom: 0.375rem; }
  .demo-tag { font-size: 0.8rem; color: rgba(255,255,255,0.38); }
  .demo-body { padding: 1.5rem 1.75rem; border-bottom: 1px solid rgba(255,255,255,0.04); flex: 1; }
  .demo-resultados { padding: 1.25rem 1.75rem; }
  .body-label { font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(255,255,255,0.2); margin-bottom: 0.875rem; }
  .pasos-lista { display: flex; flex-direction: column; gap: 0.625rem; }
  .paso-item { display: flex; align-items: flex-start; gap: 0.625rem; }
  .paso-num { font-size: 0.65rem; font-weight: 700; color: rgba(79,158,255,0.4); margin-top: 0.15rem; flex-shrink: 0; width: 1.5rem; }
  .resultado-item { display: flex; align-items: flex-start; gap: 0.5rem; }
</style>
