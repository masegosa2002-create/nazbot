---
const demos = [
  {
    id: "estetica",
    badge: "Demo 1",
    sector: "Clínica estética",
    tagline: "Del anuncio a la cita sin intervención humana",
    flujo: [
      { paso: "Captación", detalle: "Lead llega desde anuncio de Meta o web" },
      { paso: "Respuesta", detalle: "El sistema saluda y pregunta por el tratamiento en segundos" },
      { paso: "Cualificación", detalle: "¿Qué servicio buscas? ¿Ya has probado antes? ¿Cuándo quieres la cita?" },
      { paso: "Cita", detalle: "Selecciona fecha y hora desde el mismo chat. Confirmación automática." },
      { paso: "Seguimiento", detalle: "Si no responde: recordatorio a las 24h, 48h y 72h" },
    ],
    metricas: [
      { label: "Tiempo de respuesta", valor: "< 30 seg" },
      { label: "Intentos de seguimiento", valor: "4 automáticos" },
      { label: "Citas confirmadas sin gestión manual", valor: "Sí" },
    ],
    resultado: "La clínica convierte un 40% más de leads porque responde siempre, aunque sea fin de semana.",
  },
  {
    id: "servicios",
    badge: "Demo 2",
    sector: "Empresa de servicios B2B",
    tagline: "Del formulario a la llamada de cierre en piloto automático",
    flujo: [
      { paso: "Captación", detalle: "Lead rellena formulario o llama fuera de horario" },
      { paso: "Respuesta", detalle: "El sistema confirma recepción y solicita información clave" },
      { paso: "Cualificación", detalle: "Sector, número de empleados, necesidad específica, urgencia" },
      { paso: "Cita", detalle: "Propone llamada de 20 min y bloquea hueco en el calendario del comercial" },
      { paso: "Seguimiento", detalle: "Si no confirma: 2 recordatorios por WhatsApp antes de la llamada" },
    ],
    metricas: [
      { label: "Leads cualificados sin llamar primero", valor: "Sí" },
      { label: "Comercial solo ve leads preparados", valor: "Sí" },
      { label: "Leads recuperados por seguimiento", valor: "Hasta 60%" },
    ],
    resultado: "El equipo comercial deja de perseguir leads fríos y se centra en los que ya quieren hablar.",
  },
];
---

<section id="demos" class="section-py relative bg-[#0b0b0b]">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>

  <div class="mx-auto max-w-6xl px-6 lg:px-12">

    <div class="mb-16 text-center reveal">
      <span class="section-tag">Demos reales</span>
      <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-white sm:text-4xl lg:text-5xl">
        Así funciona en la práctica.
        <span class="gradient-text"> Dos ejemplos concretos.</span>
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-offset">
        Mismo sistema, adaptado a cada tipo de negocio.
      </p>
    </div>

    <div class="grid gap-6 lg:grid-cols-2">
      {demos.map((demo, di) => (
        <div class={`demo-card reveal delay-${(di + 1) * 100}`}>

          <!-- Header de la card -->
          <div class="demo-header">
            <span class="demo-badge">{demo.badge}</span>
            <h3 class="demo-sector">{demo.sector}</h3>
            <p class="demo-tagline">{demo.tagline}</p>
          </div>

          <!-- Flujo -->
          <div class="demo-flujo">
            <p class="demo-flujo-title">Lo que pasa</p>
            <div class="flujo-lista">
              {demo.flujo.map((f, i) => (
                <div class="flujo-step">
                  <div class="step-dot"></div>
                  <div class="step-content">
                    <span class="step-label">{f.paso}</span>
                    <span class="step-detalle">{f.detalle}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Métricas -->
          <div class="demo-metricas">
            <p class="demo-flujo-title">Lo que se mide</p>
            <div class="metricas-grid">
              {demo.metricas.map((m) => (
                <div class="metrica-item">
                  <span class="metrica-valor">{m.valor}</span>
                  <span class="metrica-label">{m.label}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Resultado -->
          <div class="demo-resultado">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0 mt-0.5 text-white/30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <p class="text-sm text-white/60 italic">{demo.resultado}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section-py {
    padding-top: 7rem;
    padding-bottom: 7rem;
  }

  .demo-card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .demo-header {
    padding: 1.75rem 1.75rem 1.25rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    background: rgba(255, 255, 255, 0.02);
  }

  .demo-badge {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.3);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 100px;
    padding: 0.2rem 0.625rem;
    display: inline-block;
    margin-bottom: 0.875rem;
  }

  .demo-sector {
    font-size: 1.25rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 0.375rem;
  }

  .demo-tagline {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.4);
  }

  .demo-flujo {
    padding: 1.5rem 1.75rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }

  .demo-flujo-title {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.2);
    margin-bottom: 1rem;
  }

  .flujo-lista {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .flujo-step {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .step-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.25);
    margin-top: 0.45rem;
    flex-shrink: 0;
  }

  .step-content {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 0.5rem;
    align-items: baseline;
  }

  .step-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.7);
    flex-shrink: 0;
  }

  .step-detalle {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.38);
  }

  .demo-metricas {
    padding: 1.5rem 1.75rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }

  .metricas-grid {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .metrica-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .metrica-valor {
    font-size: 0.8rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.8);
    white-space: nowrap;
  }

  .metrica-label {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.35);
    text-align: right;
  }

  .demo-resultado {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    padding: 1.25rem 1.75rem;
    background: rgba(255, 255, 255, 0.015);
    margin-top: auto;
  }
</style>
