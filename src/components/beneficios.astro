---
import { Icon } from "astro-icon/components";

const beneficios = [
  {
    icon: "mdi:tune-variant",
    metric: "+ Control",
    title: "Sabes lo que tienes",
    desc: "Ves en un golpe de vista todos los clientes que tu agente ha encontrado, a quién ya escribió y quién está esperando respuesta.",
  },
  {
    icon: "mdi:lightbulb-outline",
    metric: "+ Claridad",
    title: "Sabes qué hacer hoy",
    desc: "El sistema te dice a quién tienes que hablar hoy. No tienes que pensar. No tienes que recordar. Solo actúas.",
  },
  {
    icon: "mdi:minus-circle-outline",
    metric: "- Tiempo perdido",
    title: "Sin trabajo aburrido",
    desc: "Buscar clientes, escribir mensajes, llevar listas... todo eso lo hace el agente. Tú inviertes ese tiempo en vender.",
  },
  {
    icon: "mdi:trending-up",
    metric: "+ Ventas",
    title: "Cierras más, sin estrés",
    desc: "Cuando tienes orden y el agente trabaja por ti, llegas a más clientes en menos tiempo. Es matemática.",
  },
];
---

<section id="beneficios" class="section-py relative bg-[#0b0b0b]">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>

  <div class="mx-auto max-w-6xl px-6 lg:px-12">
    <!-- Header -->
    <div class="mb-16 text-center reveal">
      <span class="section-tag">Beneficios</span>
      <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-white sm:text-4xl lg:text-5xl">
        Lo que cambia cuando
        <span class="gradient-text"> tienes un agente</span>
      </h2>
    </div>

    <!-- Grid -->
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        beneficios.map((b, i) => (
          <div class={`card reveal delay-${(i + 1) * 100} flex flex-col gap-4`}>
            <!-- Metric grande -->
            <div class="metric-display">{b.metric}</div>

            <!-- Icon -->
            <div class="flex h-10 w-10 items-center justify-center rounded-lg border border-white/8 bg-white/4">
              <Icon name={b.icon} class="h-5 w-5 text-offset" />
            </div>

            <div>
              <h3 class="text-base font-semibold text-white">{b.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-offset">{b.desc}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .section-py {
    padding-top: 7rem;
    padding-bottom: 7rem;
  }

  .metric-display {
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: rgba(255, 255, 255, 0.15);
    line-height: 1;
  }

  .bg-white\/4 {
    background: rgba(255, 255, 255, 0.04);
  }

  .border-white\/8 {
    border-color: rgba(255, 255, 255, 0.08);
  }
</style>
