---
const reviews = [
  {
    name: "Clínica Beauty Madrid",
    text: "Antes perdíamos horas contestando WhatsApps de madrugada. Ahora el bot agenda y nosotros solo atendemos.",
    metrics: { customers: "+12%", revenue: "+2.100€", time: "18h/mes" }
  },
  {
    name: "Dra. Elena Santos (Estética)",
    text: "Tenía mis dudas sobre si sonaría a robot, pero la gente ni se da cuenta. Nos ha quitado muchísimo estrés.",
    metrics: { customers: "+15%", revenue: "+3.500€", time: "22h/mes" }
  },
  {
    name: "Ortodoncia Avanzada",
    text: "Muchos pacientes preguntaban precios y nunca respondían más. Ahora el sistema les hace seguimiento y logramos que vengan.",
    metrics: { customers: "+9%", revenue: "+4.200€", time: "15h/mes" }
  },
  {
    name: "Centro Láser Valencia",
    text: "Literalmente empezamos a ver más citas en el calendario de la noche a la mañana. Súper recomendable.",
    metrics: { customers: "+18%", revenue: "+1.900€", time: "10h/mes" }
  },
  {
    name: "Clínica Dental Sonrisas",
    text: "Antes mi recepcionista no daba abasto con el teléfono y el mostrador a la vez. Esto le ha salvado la vida.",
    metrics: { customers: "+10%", revenue: "+3.800€", time: "25h/mes" }
  },
  {
    name: "Estética Integral BCN",
    text: "Nos hemos olvidado de ir persiguiendo a la gente por WhatsApp para confirmar. Funciona automático.",
    metrics: { customers: "+14%", revenue: "+2.600€", time: "14h/mes" }
  }
];
---

<section class="relative z-20 w-full py-16 sm:py-24 mb-16 sm:mb-24 overflow-hidden bg-[#0b0b0b] border-y border-white/10 shadow-2xl">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-12 sm:mb-16 text-center">
    <h2 class="text-3xl sm:text-5xl font-extrabold tracking-tight text-white">
      Qué <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-emerald-400">piensan</span> nuestros clientes
    </h2>
    <p class="mt-4 text-lg sm:text-xl text-white/60 font-medium">
      de nuestro trabajo
    </p>
  </div>

  <div class="relative max-w-7xl mx-auto">
    <!-- Gradient masks for smooth edges -->
    <div class="absolute inset-y-0 left-0 w-8 sm:w-24 z-10 bg-gradient-to-r from-[#0b0b0b] to-transparent pointer-events-none"></div>
    <div class="absolute inset-y-0 right-0 w-8 sm:w-24 z-10 bg-gradient-to-l from-[#0b0b0b] to-transparent pointer-events-none"></div>

    <div class="flex overflow-x-auto gap-6 sm:gap-8 snap-x snap-mandatory hide-scrollbar px-6 sm:px-12 pb-8 pt-4">
      {reviews.map((review) => (
        <div class="flex-shrink-0 w-[85vw] sm:w-[420px] p-8 rounded-2xl bg-gradient-to-b from-[#161616] to-[#0f0f0f] border border-white/10 shadow-[0_8px_30px_rgb(0,0,0,0.5)] snap-center flex flex-col justify-between whitespace-normal transition-transform duration-300 hover:scale-[1.02]">
          <div>
            <div class="flex items-center gap-1.5 mb-5">
              {[...Array(5)].map(() => (
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="#FFC107" class="drop-shadow-[0_0_8px_rgba(255,193,7,0.6)]">
                  <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                </svg>
              ))}
            </div>
            
            <h4 class="text-lg font-bold text-white mb-3">{review.name}</h4>
            <p class="text-[0.95rem] text-white/70 leading-relaxed mb-8 font-medium italic">"{review.text}"</p>
          </div>
          
          <div class="grid grid-cols-3 gap-3 pt-5 border-t border-white/5 mt-auto bg-white/[0.02] -mx-8 -mb-8 px-8 pb-8 rounded-b-2xl">
            <div class="text-center">
              <span class="block text-base font-extrabold text-blue-400 drop-shadow-[0_0_8px_rgba(96,165,250,0.4)]">{review.metrics.customers}</span>
              <span class="block text-[11px] uppercase tracking-wider text-white/50 mt-1 font-semibold">Citas</span>
            </div>
            <div class="text-center border-x border-white/10">
              <span class="block text-base font-extrabold text-[#28C840] drop-shadow-[0_0_8px_rgba(40,200,64,0.4)]">{review.metrics.revenue}</span>
              <span class="block text-[11px] uppercase tracking-wider text-white/50 mt-1 font-semibold">Extra</span>
            </div>
            <div class="text-center">
              <span class="block text-base font-extrabold text-blue-400 drop-shadow-[0_0_8px_rgba(96,165,250,0.4)]">{review.metrics.time}</span>
              <span class="block text-[11px] uppercase tracking-wider text-white/50 mt-1 font-semibold">Ahorro</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Hide scrollbar for Chrome, Safari and Opera */
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }

  /* Hide scrollbar for IE, Edge and Firefox */
  .hide-scrollbar {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }
</style>
