---
const items = [
  "WhatsApp Business con respuesta automática",
  "Webchat instalado en tu web",
  "Integración con tu agenda o calendario",
  "Panel centralizado con todos los leads",
  "Cualificación personalizada según tu negocio",
  "Seguimiento automático hasta 14 días",
  "1 semana de estabilización incluida",
  "Garantía de 15 días sin coste adicional",
  "Vídeo Loom explicativo del sistema",
  "Diagrama del flujo para tu equipo",
];
---

<section id="incluye" class="section-py relative bg-[#0d0d0d]">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/8 to-transparent"></div>

  <div class="mx-auto max-w-4xl px-6 lg:px-12">
    <div class="mb-14 text-center reveal">
      <span class="section-tag">Qué incluye</span>
      <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
        Sin letra pequeña.
        <span class="gradient-text"> Lo que está dentro, está dentro.</span>
      </h2>
    </div>

    <div class="grid gap-3 sm:grid-cols-2 reveal">
      {items.map((item) => (
        <div class="item-row">
          <div class="item-check">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
              <path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <span class="text-sm text-white/70">{item}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .item-row {
    display: flex; align-items: flex-start; gap: 0.875rem;
    padding: 1rem 1.25rem;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 10px;
    transition: border-color 0.2s ease;
  }
  .item-row:hover { border-color: rgba(79,158,255,0.15); }
  .item-check {
    display: flex; align-items: center; justify-content: center;
    width: 20px; height: 20px; border-radius: 50%; flex-shrink: 0;
    background: rgba(79,158,255,0.08);
    border: 1px solid rgba(79,158,255,0.2);
    color: #4F9EFF; margin-top: 0.05rem;
  }
</style>
